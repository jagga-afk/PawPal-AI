classDiagram
    class Owner {
        +name: str
        +availability_minutes: int
        +preferences: list[str]
        +add_preference()
        +update_availability()
    }

    class Pet {
        +name: str
        +species: str
        +age: int
        +special_needs: list[str]
        +notes: str
    }

    class Task {
        +title: str
        +category: str
        +duration_minutes: int
        +priority: int
        +preferred_time: str
        +recurring: bool
        +update_task()
    }

    class TaskManager {
        +tasks: list[Task]
        +add_task(task)
        +edit_task(task)
        +remove_task(task)
        +sort_tasks()
    }

    class DailyPlan {
        +date: date
        +scheduled_tasks: list[Task]
        +reasoning: list[str]
        +display_plan()
    }

    class Scheduler {
        +generate_plan(owner, pet, task_manager) DailyPlan
        +prioritize_tasks()
        +resolve_conflicts()
        +explain_reasoning()
    }

    Owner "1" --> "1" Pet : owns
    Owner "1" --> "1" TaskManager : manages
    TaskManager "1" --> "0..*" Task : contains
    Pet "1" --> "0..*" Task : requires
    Scheduler --> DailyPlan : creates
    Scheduler --> TaskManager : evaluates
    DailyPlan --> Task : includes
